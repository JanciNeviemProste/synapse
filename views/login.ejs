<!DOCTYPE html>
<html lang="sk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Prihlásenie | Synapse System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center">
  <div class="w-full max-w-sm px-4">
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-8">
      <div class="flex items-center justify-center gap-2 mb-6">
        <i data-lucide="zap" class="w-7 h-7 text-indigo-600"></i>
        <span class="text-2xl font-bold text-gray-900">Synapse</span>
      </div>
      <% if (error) { %>
        <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700">
          Nesprávne heslo, skús znova.
        </div>
      <% } %>
      <form method="POST" action="/login" class="space-y-4">
        <input type="hidden" name="next" value="<%= next %>">
        <div>
          <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Admin heslo</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            autofocus
            autocomplete="current-password"
            class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
          >
        </div>
        <button
          type="submit"
          class="w-full px-4 py-2.5 bg-indigo-600 text-white font-medium rounded-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
        >
          Prihlásiť sa
        </button>
      </form>
    </div>
  </div>
  <script>lucide.createIcons();</script>
</body>
</html>
