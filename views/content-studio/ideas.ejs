<%- include('../layouts/header', { title: 'Nápady | Content Studio', currentPath: '/content-studio' }) %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Nápady</h1>
  <p class="text-sm text-gray-500 mt-1">Zachytené content nápady — schvaľuj, upravuj, spájaj</p>
</div>

<%- include('_subnav', { subnavPath: '/content-studio/ideas' }) %>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <% if (ideas.length === 0) { %>
    <p class="text-sm text-gray-400 p-6">Žiadne nápady. Vytvor prvý cez Rýchly nápad na prehľade.</p>
  <% } else { %>
  <table class="w-full text-sm">
    <thead class="bg-gray-50 text-xs text-gray-500 uppercase tracking-wide">
      <tr>
        <th class="text-left px-4 py-3 w-8"><input type="checkbox" id="select-all"></th>
        <th class="text-left px-4 py-3">Nápad</th>
        <th class="text-left px-4 py-3 hidden md:table-cell">Cieľ</th>
        <th class="text-left px-4 py-3">Status</th>
        <th class="text-right px-4 py-3">Akcie</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% for (const idea of ideas) { %>
      <tr data-id="<%= idea.id %>">
        <td class="px-4 py-3"><input type="checkbox" class="idea-check" value="<%= idea.id %>"></td>
        <td class="px-4 py-3">
          <div class="font-medium text-gray-900"><%= idea.title %></div>
          <% if (idea.keyMessage) { %><div class="text-xs text-gray-500 mt-0.5"><%= idea.keyMessage %></div><% } %>
        </td>
        <td class="px-4 py-3 hidden md:table-cell text-gray-600"><%= idea.suggestedGoal || '—' %></td>
        <td class="px-4 py-3">
          <select class="idea-status text-xs rounded border-gray-300 py-1" data-id="<%= idea.id %>">
            <% for (const s of ['NEW','APPROVED','CONVERTED','REJECTED','ARCHIVED']) { %>
              <option value="<%= s %>" <%= idea.status === s ? 'selected' : '' %>><%= s %></option>
            <% } %>
          </select>
        </td>
        <td class="px-4 py-3 text-right">
          <button class="idea-delete text-red-500 hover:text-red-700 text-xs" data-id="<%= idea.id %>">Zmazať</button>
        </td>
      </tr>
      <% } %>
    </tbody>
  </table>
  <div class="px-4 py-3 border-t border-gray-100 bg-gray-50">
    <button id="merge-btn" class="text-sm text-indigo-600 hover:underline disabled:text-gray-400" disabled>Spojiť vybrané nápady</button>
  </div>
  <% } %>
</div>

<script>
const checks = () => [...document.querySelectorAll('.idea-check:checked')].map(c => c.value);
document.querySelectorAll('.idea-check, #select-all').forEach(el => el.addEventListener('change', () => {
  if (el.id === 'select-all') document.querySelectorAll('.idea-check').forEach(c => c.checked = el.checked);
  document.getElementById('merge-btn').disabled = checks().length < 2;
}));

document.getElementById('merge-btn')?.addEventListener('click', async () => {
  const res = await fetch('/api/content-studio/ideas/merge', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ ids: checks() }),
  });
  if (res.ok) location.reload(); else alert('Spojenie zlyhalo');
});

document.querySelectorAll('.idea-status').forEach(sel => sel.addEventListener('change', async () => {
  await fetch('/api/content-studio/ideas/' + sel.dataset.id, {
    method: 'PATCH', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status: sel.value }),
  });
}));

document.querySelectorAll('.idea-delete').forEach(btn => btn.addEventListener('click', async () => {
  if (!confirm('Zmazať nápad?')) return;
  const res = await fetch('/api/content-studio/ideas/' + btn.dataset.id, { method: 'DELETE' });
  if (res.ok) btn.closest('tr').remove();
}));
</script>

<%- include('../layouts/footer') %>
