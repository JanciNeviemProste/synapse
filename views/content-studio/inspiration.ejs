<%- include('../layouts/header', { title: 'Inšpirácie | Content Studio', currentPath: '/content-studio' }) %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Inšpiračná knižnica</h1>
  <p class="text-sm text-gray-500 mt-1">Manuálne vklady — žiadny scraping. AI extrahuje len vzory, nikdy nekopíruje formulácie.</p>
</div>

<%- include('_subnav', { subnavPath: '/content-studio/inspiration' }) %>

<div class="grid lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-3">
    <% if (sources.length === 0) { %>
      <div class="bg-white rounded-xl border border-gray-200 p-6 text-sm text-gray-400">Žiadne inšpirácie — pridaj prvú vpravo.</div>
    <% } %>
    <% for (const s of sources) { %>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <div class="flex items-center gap-2">
            <h3 class="font-semibold text-gray-900 truncate"><%= s.title %></h3>
            <span class="text-[10px] px-1.5 py-0.5 rounded bg-gray-100 text-gray-600"><%= s.type %></span>
            <span class="text-[10px] px-1.5 py-0.5 rounded <%= s.status === 'analyzed' ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-gray-600' %>"><%= s.status %></span>
          </div>
          <% if (s.sourceUrl) { %><a href="<%= s.sourceUrl %>" target="_blank" rel="noopener" class="text-xs text-indigo-600 hover:underline break-all"><%= s.sourceUrl %></a><% } %>
          <% if (s.userNotes) { %><p class="text-xs text-gray-500 mt-1"><%= s.userNotes %></p><% } %>
        </div>
        <div class="flex items-center gap-2 shrink-0 text-xs">
          <button class="insp-analyze text-indigo-600 hover:underline" data-id="<%= s.id %>">Analyzovať vzory</button>
          <button class="insp-delete text-red-500 hover:text-red-700" data-id="<%= s.id %>">Zmazať</button>
        </div>
      </div>
      <% const patterns = s.extractedPatterns && s.extractedPatterns.patterns; %>
      <% if (patterns && patterns.length) { %>
      <div class="mt-3 pt-3 border-t border-gray-100 flex flex-wrap gap-1.5">
        <% for (const p of patterns) { %>
          <span class="text-[11px] px-2 py-1 rounded-full bg-indigo-50 text-indigo-700" title="<%= p.note || '' %>"><%= p.category %>: <%= p.pattern %></span>
        <% } %>
      </div>
      <% } %>
    </div>
    <% } %>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 p-5 h-fit">
    <h2 class="font-semibold text-gray-900 mb-3">Pridať inšpiráciu</h2>
    <form id="insp-form" class="space-y-3">
      <select name="type" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm bg-white">
        <option value="INSTAGRAM_REEL">Instagram Reel (URL)</option>
        <option value="INSTAGRAM_PROFILE">Instagram profil (URL)</option>
        <option value="TRANSCRIPT">Prepis videa</option>
        <option value="MANUAL_NOTE">Manuálna poznámka</option>
      </select>
      <input name="title" required maxlength="200" placeholder="Názov / popis" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
      <input name="sourceUrl" maxlength="1000" placeholder="URL (voliteľné)" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
      <textarea name="transcript" rows="3" maxlength="50000" placeholder="Prepis (voliteľné)" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"></textarea>
      <textarea name="userNotes" rows="2" maxlength="10000" placeholder="Čo sa ti na tom páči?" class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"></textarea>
      <button class="w-full px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700">Uložiť</button>
    </form>
  </div>
</div>

<script>
document.getElementById('insp-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const f = new FormData(e.target);
  const res = await fetch('/api/content-studio/inspiration', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      type: f.get('type'), title: f.get('title'),
      sourceUrl: f.get('sourceUrl') || undefined,
      transcript: f.get('transcript') || undefined,
      userNotes: f.get('userNotes') || undefined,
    }),
  });
  if (res.ok) location.reload(); else alert('Uloženie zlyhalo');
});

document.querySelectorAll('.insp-analyze').forEach(b => b.addEventListener('click', async () => {
  b.textContent = 'Analyzujem...';
  const res = await fetch('/api/content-studio/inspiration/' + b.dataset.id + '/analyze', { method: 'POST' });
  if (res.ok) location.reload(); else { alert('Analýza zlyhala'); b.textContent = 'Analyzovať vzory'; }
}));

document.querySelectorAll('.insp-delete').forEach(b => b.addEventListener('click', async () => {
  if (!confirm('Zmazať inšpiráciu?')) return;
  const res = await fetch('/api/content-studio/inspiration/' + b.dataset.id, { method: 'DELETE' });
  if (res.ok) location.reload();
}));
</script>

<%- include('../layouts/footer') %>
