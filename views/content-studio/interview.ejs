<%- include('../layouts/header', { title: 'AI Interview | Content Studio', currentPath: '/content-studio' }) %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">AI Content Interview</h1>
  <p class="text-sm text-gray-500 mt-1">AI stratég sa ťa pýta krátke otázky a z rozhovoru vytvorí content brief</p>
</div>

<%- include('_subnav', { subnavPath: '/content-studio/interview' }) %>

<div class="bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 mb-6 text-sm text-amber-800">
  ⚠ Neuvádzajte mená ani identifikačné údaje klientov, pokiaľ na to nemáte oprávnenie.
</div>

<div id="realtime-banner" class="hidden bg-indigo-50 border border-indigo-200 rounded-lg px-4 py-3 mb-6 text-sm text-indigo-800">
  🎙 Hlasový realtime režim je dostupný (OpenAI Realtime). Textový režim nižšie funguje vždy.
</div>

<div class="bg-white rounded-xl border border-gray-200 flex flex-col" style="min-height: 420px">
  <div id="chat" class="flex-1 p-6 space-y-3 overflow-y-auto"></div>
  <div class="border-t border-gray-100 p-4">
    <div id="chat-controls" class="flex gap-2">
      <button id="start-btn" class="px-5 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700">Začať rozhovor</button>
    </div>
    <form id="answer-form" class="hidden flex gap-2">
      <input id="answer-input" autocomplete="off" maxlength="4000" placeholder="Tvoja odpoveď..." class="flex-1 rounded-lg border border-gray-300 px-4 py-2.5 text-sm focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 focus:outline-none">
      <button type="submit" class="px-4 py-2.5 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700">Odoslať</button>
      <button type="button" id="finish-btn" class="px-4 py-2.5 bg-white border border-gray-300 text-sm font-medium rounded-lg hover:bg-gray-50">Ukončiť a vytvoriť brief</button>
    </form>
  </div>
</div>

<div id="brief-result" class="hidden mt-6 bg-white rounded-xl border border-green-200 p-6"></div>

<script>
(() => {
  const history = [];
  const $ = (id) => document.getElementById(id);

  fetch('/api/content-studio/interview/realtime-availability')
    .then(r => r.json())
    .then(d => { if (d.available) $('realtime-banner').classList.remove('hidden'); })
    .catch(() => {});

  const bubble = (role, text) => {
    const div = document.createElement('div');
    div.className = role === 'ai' ? 'flex' : 'flex justify-end';
    div.innerHTML = '<div class="max-w-[80%] rounded-2xl px-4 py-2.5 text-sm ' +
      (role === 'ai' ? 'bg-gray-100 text-gray-900' : 'bg-indigo-600 text-white') + '"></div>';
    div.firstChild.textContent = text;
    $('chat').appendChild(div);
    $('chat').scrollTop = $('chat').scrollHeight;
  };

  const askNext = async () => {
    bubble('ai', '…');
    const placeholder = $('chat').lastChild;
    try {
      const res = await fetch('/api/content-studio/interview/next', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ history }),
      });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();
      placeholder.remove();
      if (data.done) {
        bubble('ai', 'Mám dosť informácií — môžeš ukončiť rozhovor a vytvoriť brief.');
        return;
      }
      history.push({ role: 'ai', text: data.question });
      bubble('ai', data.question);
    } catch (err) {
      placeholder.remove();
      bubble('ai', 'Chyba: ' + err.message);
    }
  };

  $('start-btn').addEventListener('click', () => {
    $('chat-controls').classList.add('hidden');
    $('answer-form').classList.remove('hidden');
    $('answer-form').classList.add('flex');
    askNext();
  });

  $('answer-form').addEventListener('submit', (e) => {
    e.preventDefault();
    const text = $('answer-input').value.trim();
    if (!text) return;
    history.push({ role: 'user', text });
    bubble('user', text);
    $('answer-input').value = '';
    askNext();
  });

  $('finish-btn').addEventListener('click', async () => {
    const result = $('brief-result');
    result.classList.remove('hidden');
    result.innerHTML = '<p class="text-sm text-gray-600">Vytváram content brief...</p>';
    try {
      const res = await fetch('/api/content-studio/interview/finish', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ history }),
      });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();
      const brief = data.session.extractedData || {};
      const list = (title, items) => (items && items.length)
        ? '<div class="mt-2"><span class="text-xs font-semibold text-gray-500 uppercase">' + title + '</span>' +
          items.map(x => '<div class="text-sm text-gray-800">• ' + x + '</div>').join('') + '</div>'
        : '';
      result.innerHTML =
        '<p class="text-sm font-medium text-green-700 mb-1">Brief hotový — vytvorených ' + data.ideas.length + ' nápadov.</p>' +
        '<p class="text-sm text-gray-800">' + (brief.summary || '') + '</p>' +
        list('Kľúčové myšlienky', brief.keyThoughts) +
        list('Navrhované piliere', brief.suggestedPillars) +
        list('Chýbajúce informácie', brief.missingInformation) +
        list('Upozornenia', brief.warnings) +
        '<a href="/content-studio/ideas" class="inline-block mt-3 text-sm text-indigo-600 hover:underline">Spravovať nápady →</a>';
    } catch (err) {
      result.innerHTML = '<p class="text-sm text-red-600">Brief zlyhal: ' + err.message + '</p>';
    }
  });
})();
</script>

<%- include('../layouts/footer') %>
