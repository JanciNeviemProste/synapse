<!DOCTYPE html>
<html lang="sk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rezervacia konzultacie | Synapse</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    .slot-btn.selected {
      background-color: #4f46e5;
      color: white;
      border-color: #4f46e5;
    }
    .slot-btn:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }
  </style>
</head>
<body class="bg-gray-50 min-h-screen">

  <!-- Header with gradient -->
  <div class="bg-gradient-to-br from-indigo-600 via-indigo-700 to-purple-800 text-white">
    <div class="max-w-3xl mx-auto px-4 py-12 text-center">
      <div class="flex items-center justify-center gap-2 mb-4">
        <i data-lucide="zap" class="w-8 h-8"></i>
        <span class="text-2xl font-bold">Synapse</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold mb-3">Rezervujte si bezplatnu konzultaciu</h1>
      <p class="text-indigo-200 text-lg max-w-xl mx-auto">
        Porozpravam sa s vami o vasich potrebach a navrhnem riesenie na mieru.
        Bez zavazkov, 30 minut, online cez Google Meet.
      </p>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 -mt-6">

    <!-- Booking Form Card -->
    <div id="booking-form-section" class="bg-white rounded-2xl shadow-lg border border-gray-100 p-6 sm:p-8 mb-8">

      <!-- Date Selection -->
      <div class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-1">Vyber terminu</h2>
        <p class="text-sm text-gray-500 mb-4">Vyberte si den a cas, ktory vam vyhovuje</p>

        <div id="slots-loading" class="text-center py-8">
          <i data-lucide="loader" class="w-6 h-6 text-indigo-500 inline animate-spin"></i>
          <p class="text-sm text-gray-500 mt-2">Nacitavam dostupne terminy...</p>
        </div>

        <div id="slots-container" class="hidden">
          <!-- Days row -->
          <div id="days-row" class="flex gap-2 overflow-x-auto pb-3 mb-4"></div>
          <!-- Time slots -->
          <div id="times-grid" class="grid grid-cols-3 sm:grid-cols-4 gap-2"></div>
        </div>

        <div id="slots-empty" class="hidden text-center py-8">
          <i data-lucide="calendar-x" class="w-8 h-8 text-gray-300 mx-auto mb-2"></i>
          <p class="text-sm text-gray-500">Ziadne dostupne terminy. Skuste neskor.</p>
        </div>
      </div>

      <!-- Contact Form -->
      <form id="booking-form" class="space-y-4">
        <input type="hidden" id="selected-datetime" name="dateTime" value="">
        <% if (typeof ref !== 'undefined' && ref) { %>
          <input type="hidden" id="booking-ref" name="ref" value="<%= ref %>">
        <% } %>

        <div>
          <label for="client-name" class="block text-sm font-medium text-gray-700 mb-1">Meno a priezvisko *</label>
          <input
            type="text"
            id="client-name"
            name="clientName"
            required
            class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 focus:outline-none"
            placeholder="Jan Novak"
          >
        </div>

        <div>
          <label for="client-email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
          <input
            type="email"
            id="client-email"
            name="clientEmail"
            required
            class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 focus:outline-none"
            placeholder="jan@firma.sk"
          >
        </div>

        <div>
          <label for="client-phone" class="block text-sm font-medium text-gray-700 mb-1">Telefon <span class="text-gray-400">(volitelne)</span></label>
          <input
            type="tel"
            id="client-phone"
            name="clientPhone"
            class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 focus:outline-none"
            placeholder="+421 9XX XXX XXX"
          >
        </div>

        <div>
          <label for="client-notes" class="block text-sm font-medium text-gray-700 mb-1">Poznamky <span class="text-gray-400">(volitelne)</span></label>
          <textarea
            id="client-notes"
            name="notes"
            rows="3"
            class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 focus:outline-none resize-y"
            placeholder="Co by ste chceli prebrat na konzultacii?"
          ></textarea>
        </div>

        <button
          type="submit"
          id="submit-btn"
          disabled
          class="w-full py-3 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 focus:ring-2 focus:ring-indigo-200 focus:outline-none disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2"
        >
          <i data-lucide="check-circle" class="w-4 h-4"></i>
          Potvrdit rezervaciu
        </button>
      </form>
    </div>

    <!-- Success Message (hidden by default) -->
    <div id="booking-success" class="bg-white rounded-2xl shadow-lg border border-green-100 p-8 mb-8 text-center hidden">
      <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
        <i data-lucide="check" class="w-8 h-8 text-green-600"></i>
      </div>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Rezervacia potvrdena</h2>
      <p class="text-gray-600 mb-4">Dakujeme za vasu rezervaciu. Potvrdenie sme vam odoslali na email.</p>
      <div id="success-details" class="bg-gray-50 rounded-lg p-4 text-left max-w-sm mx-auto">
        <p class="text-sm text-gray-500">Datum: <span id="success-date" class="font-medium text-gray-900"></span></p>
        <p class="text-sm text-gray-500 mt-1">Meet link: <a id="success-meet" href="#" target="_blank" class="font-medium text-indigo-600 hover:text-indigo-800">Otvorit</a></p>
      </div>
    </div>

    <!-- Footer -->
    <div class="text-center py-8 text-xs text-gray-400">
      Synapse System &mdash; Profesionalne webove riesenia
    </div>
  </div>

<script>
document.addEventListener('DOMContentLoaded', async () => {
  const slotsContainer = document.getElementById('slots-container');
  const slotsLoading = document.getElementById('slots-loading');
  const slotsEmpty = document.getElementById('slots-empty');
  const daysRow = document.getElementById('days-row');
  const timesGrid = document.getElementById('times-grid');
  const submitBtn = document.getElementById('submit-btn');
  const selectedDatetimeInput = document.getElementById('selected-datetime');

  let allSlots = [];
  let selectedDate = null;
  let selectedSlot = null;

  // Load available slots
  try {
    const res = await fetch('/api/booking/slots?days=14');
    const data = await res.json();

    slotsLoading.classList.add('hidden');

    if (data.success && data.data && data.data.length > 0) {
      allSlots = data.data;

      // Group by date
      const byDate = {};
      allSlots.forEach(slot => {
        const d = new Date(slot).toLocaleDateString('sk-SK', { weekday: 'short', day: 'numeric', month: 'short' });
        const dateKey = new Date(slot).toISOString().split('T')[0];
        if (!byDate[dateKey]) byDate[dateKey] = { label: d, slots: [] };
        byDate[dateKey].slots.push(slot);
      });

      // Render day buttons
      Object.keys(byDate).forEach((dateKey, i) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'flex-shrink-0 px-4 py-2 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 hover:border-indigo-400 hover:bg-indigo-50 whitespace-nowrap';
        btn.textContent = byDate[dateKey].label;
        btn.addEventListener('click', () => {
          selectDay(dateKey, byDate[dateKey].slots, btn);
        });
        daysRow.appendChild(btn);

        // Auto-select first day
        if (i === 0) {
          selectDay(dateKey, byDate[dateKey].slots, btn);
        }
      });

      slotsContainer.classList.remove('hidden');
    } else {
      slotsEmpty.classList.remove('hidden');
    }
  } catch (e) {
    slotsLoading.classList.add('hidden');
    slotsEmpty.classList.remove('hidden');
  }

  function selectDay(dateKey, slots, btn) {
    selectedDate = dateKey;
    selectedSlot = null;
    selectedDatetimeInput.value = '';
    submitBtn.disabled = true;

    // Highlight day button
    daysRow.querySelectorAll('button').forEach(b => {
      b.classList.remove('bg-indigo-600', 'text-white', 'border-indigo-600');
      b.classList.add('border-gray-300', 'text-gray-700');
    });
    btn.classList.remove('border-gray-300', 'text-gray-700');
    btn.classList.add('bg-indigo-600', 'text-white', 'border-indigo-600');

    // Render time slots
    timesGrid.innerHTML = '';
    slots.forEach(slot => {
      const time = new Date(slot).toLocaleTimeString('sk-SK', { hour: '2-digit', minute: '2-digit' });
      const slotBtn = document.createElement('button');
      slotBtn.type = 'button';
      slotBtn.className = 'slot-btn px-3 py-2 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 hover:border-indigo-400 hover:bg-indigo-50';
      slotBtn.textContent = time;
      slotBtn.addEventListener('click', () => {
        selectSlot(slot, slotBtn);
      });
      timesGrid.appendChild(slotBtn);
    });
  }

  function selectSlot(slot, btn) {
    selectedSlot = slot;
    selectedDatetimeInput.value = slot;
    submitBtn.disabled = false;

    timesGrid.querySelectorAll('.slot-btn').forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
  }

  // Submit form
  document.getElementById('booking-form').addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!selectedSlot) return;

    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i data-lucide="loader" class="w-4 h-4 animate-spin"></i> Spracovavam...';
    lucide.createIcons();

    try {
      const body = {
        clientName: document.getElementById('client-name').value,
        clientEmail: document.getElementById('client-email').value,
        clientPhone: document.getElementById('client-phone').value || undefined,
        dateTime: selectedSlot,
        notes: document.getElementById('client-notes').value || undefined,
      };

      const res = await fetch('/api/booking', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const data = await res.json();

      if (data.success) {
        document.getElementById('booking-form-section').classList.add('hidden');
        document.getElementById('booking-success').classList.remove('hidden');

        document.getElementById('success-date').textContent =
          new Date(selectedSlot).toLocaleString('sk-SK', { weekday: 'long', day: 'numeric', month: 'long', hour: '2-digit', minute: '2-digit' });

        if (data.data && data.data.meetLink) {
          document.getElementById('success-meet').href = data.data.meetLink;
        } else {
          document.getElementById('success-meet').textContent = 'Bude zaslany emailom';
          document.getElementById('success-meet').removeAttribute('href');
        }

        lucide.createIcons();
      } else {
        throw new Error('Booking failed');
      }
    } catch (err) {
      submitBtn.disabled = false;
      submitBtn.innerHTML = '<i data-lucide="check-circle" class="w-4 h-4"></i> Potvrdit rezervaciu';
      lucide.createIcons();
      alert('Nepodarilo sa vytvorit rezervaciu. Skuste to prosim znova.');
    }
  });

  lucide.createIcons();
});
</script>

</body>
</html>
