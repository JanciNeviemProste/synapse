<%- include('../layouts/header', { title: 'Booking - Admin', currentPath: '/booking' }) %>

<!-- Page Header -->
<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Booking - Sprava</h1>
    <p class="text-sm text-gray-500 mt-1">Prehad nadchadzajucich a minulych rezervacii</p>
  </div>
  <a href="/booking/public" target="_blank" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-indigo-600 rounded-lg hover:bg-indigo-700">
    <i data-lucide="external-link" class="w-4 h-4"></i>
    Verejna stranka
  </a>
</div>

<!-- Bookings Table -->
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="bg-gray-50 border-b border-gray-200">
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Datum a cas</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Klient</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Meet link</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Akcie</th>
        </tr>
      </thead>
      <tbody id="bookings-body" class="divide-y divide-gray-200">
        <tr>
          <td colspan="6" class="px-6 py-12 text-center text-sm text-gray-400">
            <i data-lucide="loader" class="w-5 h-5 inline animate-spin mr-2"></i>
            Nacitavam rezervacie...
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', async () => {
  const tbody = document.getElementById('bookings-body');

  function statusBadge(status) {
    const map = {
      'PENDING': 'bg-yellow-100 text-yellow-800',
      'CONFIRMED': 'bg-green-100 text-green-800',
      'COMPLETED': 'bg-blue-100 text-blue-800',
      'CANCELLED': 'bg-red-100 text-red-800',
    };
    const labels = {
      'PENDING': 'Cakajuca',
      'CONFIRMED': 'Potvrdena',
      'COMPLETED': 'Dokoncena',
      'CANCELLED': 'Zrusena',
    };
    const cls = map[status] || 'bg-gray-100 text-gray-700';
    const label = labels[status] || status;
    return '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ' + cls + '">' + label + '</span>';
  }

  async function loadBookings() {
    try {
      const res = await apiFetch('/api/booking');
      if (!res.success || !res.data || res.data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6" class="px-6 py-12 text-center text-sm text-gray-400">' +
          '<i data-lucide="calendar" class="w-8 h-8 text-gray-300 mx-auto mb-3"></i>' +
          '<p>Ziadne rezervacie</p></td></tr>';
        lucide.createIcons();
        return;
      }

      tbody.innerHTML = res.data.map(function(b) {
        const date = formatDate(b.dateTime);
        const meetLink = b.meetLink
          ? '<a href="' + b.meetLink + '" target="_blank" class="text-indigo-600 hover:text-indigo-800 text-xs">Otvorit</a>'
          : '<span class="text-xs text-gray-400">--</span>';
        const cancelBtn = b.status !== 'CANCELLED'
          ? '<button onclick="cancelBooking(\'' + b.id + '\')" class="text-xs text-red-600 hover:text-red-800">Zrusit</button>'
          : '';

        return '<tr class="hover:bg-gray-50">' +
          '<td class="px-6 py-4 text-sm text-gray-600 whitespace-nowrap">' + date + '</td>' +
          '<td class="px-6 py-4 text-sm font-medium text-gray-900">' + (b.clientName || '--') + '</td>' +
          '<td class="px-6 py-4 text-sm text-gray-600">' + (b.clientEmail || '--') + '</td>' +
          '<td class="px-6 py-4 whitespace-nowrap">' + meetLink + '</td>' +
          '<td class="px-6 py-4 whitespace-nowrap">' + statusBadge(b.status) + '</td>' +
          '<td class="px-6 py-4 whitespace-nowrap">' + cancelBtn + '</td>' +
          '</tr>';
      }).join('');
      lucide.createIcons();
    } catch (err) {
      tbody.innerHTML = '<tr><td colspan="6" class="px-6 py-12 text-center text-sm text-red-500">Chyba pri nacitani rezervacii</td></tr>';
    }
  }

  window.cancelBooking = async function(id) {
    if (!confirm('Naozaj chcete zrusit tuto rezervaciu?')) return;

    try {
      await apiFetch('/api/booking/' + id, { method: 'DELETE' });
      loadBookings();
    } catch (err) {
      console.error('Failed to cancel booking:', err);
      alert('Nepodarilo sa zrusit rezervaciu.');
    }
  };

  loadBookings();
});
</script>

<%- include('../layouts/footer') %>
