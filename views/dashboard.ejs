<%- include('layouts/header', { title: title, currentPath: currentPath }) %>

<!-- Page Header -->
<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="text-sm text-gray-500 mt-1">Prehad systemu Synapse</p>
  </div>
  <div class="text-sm text-gray-400">
    <%= new Date().toLocaleDateString('sk-SK', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
  </div>
</div>

<!-- Stats Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
  <!-- Leads Today -->
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Leady dnes</span>
      <i data-lucide="users" class="w-4 h-4 text-indigo-500"></i>
    </div>
    <div id="stat-leads" class="text-2xl font-bold text-gray-900">--</div>
    <div class="flex items-center gap-3 mt-2 text-xs text-gray-500">
      <span id="stat-leads-new" class="flex items-center gap-1">
        <span class="w-2 h-2 rounded-full bg-blue-400"></span> Novych: --
      </span>
      <span id="stat-leads-contacted" class="flex items-center gap-1">
        <span class="w-2 h-2 rounded-full bg-yellow-400"></span> Kontakt: --
      </span>
      <span id="stat-leads-hot" class="flex items-center gap-1">
        <span class="w-2 h-2 rounded-full bg-red-400"></span> Hot: --
      </span>
    </div>
  </div>

  <!-- Next Booking -->
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Nasledujuci booking</span>
      <i data-lucide="calendar" class="w-4 h-4 text-green-500"></i>
    </div>
    <div id="stat-booking" class="text-2xl font-bold text-gray-900">--</div>
    <p id="stat-booking-detail" class="text-xs text-gray-500 mt-2">Nacitavam...</p>
  </div>

  <!-- Last AI Coder Task -->
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Posledny AI Coder</span>
      <i data-lucide="code-2" class="w-4 h-4 text-purple-500"></i>
    </div>
    <div id="stat-coder" class="text-2xl font-bold text-gray-900">--</div>
    <p id="stat-coder-detail" class="text-xs text-gray-500 mt-2">Nacitavam...</p>
  </div>

  <!-- Pending Design Tasks -->
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Figma ulohy</span>
      <i data-lucide="figma" class="w-4 h-4 text-orange-500"></i>
    </div>
    <div id="stat-figma" class="text-2xl font-bold text-gray-900">--</div>
    <p id="stat-figma-detail" class="text-xs text-gray-500 mt-2">Nacitavam...</p>
  </div>

  <!-- Clone Requests -->
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Clone poziadavky</span>
      <i data-lucide="copy" class="w-4 h-4 text-teal-500"></i>
    </div>
    <div id="stat-cloner" class="text-2xl font-bold text-gray-900">--</div>
    <p id="stat-cloner-detail" class="text-xs text-gray-500 mt-2">Nacitavam...</p>
  </div>
</div>

<!-- Quick Actions -->
<div class="mb-8">
  <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Rychle akcie</h2>
  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3">
    <a href="/leads" class="flex items-center gap-3 bg-white rounded-xl border border-gray-200 p-4 hover:border-indigo-300 hover:shadow-sm">
      <div class="w-10 h-10 rounded-lg bg-indigo-50 flex items-center justify-center">
        <i data-lucide="users" class="w-5 h-5 text-indigo-600"></i>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-900">Leads</p>
        <p class="text-xs text-gray-500">Kanban board</p>
      </div>
    </a>
    <a href="/coder" class="flex items-center gap-3 bg-white rounded-xl border border-gray-200 p-4 hover:border-indigo-300 hover:shadow-sm">
      <div class="w-10 h-10 rounded-lg bg-purple-50 flex items-center justify-center">
        <i data-lucide="code-2" class="w-5 h-5 text-purple-600"></i>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-900">AI Coder</p>
        <p class="text-xs text-gray-500">Generovat kod</p>
      </div>
    </a>
    <a href="/booking/public" class="flex items-center gap-3 bg-white rounded-xl border border-gray-200 p-4 hover:border-indigo-300 hover:shadow-sm">
      <div class="w-10 h-10 rounded-lg bg-green-50 flex items-center justify-center">
        <i data-lucide="calendar" class="w-5 h-5 text-green-600"></i>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-900">Booking</p>
        <p class="text-xs text-gray-500">Verejna stranka</p>
      </div>
    </a>
    <a href="/figma" class="flex items-center gap-3 bg-white rounded-xl border border-gray-200 p-4 hover:border-indigo-300 hover:shadow-sm">
      <div class="w-10 h-10 rounded-lg bg-orange-50 flex items-center justify-center">
        <i data-lucide="figma" class="w-5 h-5 text-orange-600"></i>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-900">Figma</p>
        <p class="text-xs text-gray-500">Design pipeline</p>
      </div>
    </a>
    <a href="/cloner/admin" class="flex items-center gap-3 bg-white rounded-xl border border-gray-200 p-4 hover:border-indigo-300 hover:shadow-sm">
      <div class="w-10 h-10 rounded-lg bg-teal-50 flex items-center justify-center">
        <i data-lucide="copy" class="w-5 h-5 text-teal-600"></i>
      </div>
      <div>
        <p class="text-sm font-semibold text-gray-900">Cloner</p>
        <p class="text-xs text-gray-500">Sprava poziadaviek</p>
      </div>
    </a>
  </div>
</div>

<!-- Weekly Conversions Chart -->
<div class="bg-white rounded-xl border border-gray-200 p-6">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider">Tyzdenne konverzie</h2>
    <i data-lucide="bar-chart-3" class="w-4 h-4 text-gray-400"></i>
  </div>
  <div id="weekly-chart" class="flex items-end gap-2 h-40">
    <% const days = ['Po', 'Ut', 'St', 'St', 'Pi', 'So', 'Ne']; %>
    <% days.forEach(function(day, i) { %>
      <div class="flex-1 flex flex-col items-center gap-2">
        <div id="bar-<%= i %>" class="w-full bg-indigo-100 rounded-t-md" style="height: 20%"></div>
        <span class="text-xs text-gray-500"><%= day %></span>
      </div>
    <% }); %>
  </div>
  <p class="text-xs text-gray-400 mt-4 text-center">Data sa aktualizuju automaticky</p>
</div>

<script>
document.addEventListener('DOMContentLoaded', async () => {
  // Load lead stats
  try {
    const res = await apiFetch('/api/leads');
    if (res.success && res.data) {
      const leads = res.data;
      document.getElementById('stat-leads').textContent = leads.length;
      const newCount = leads.filter(l => l.status === 'NEW').length;
      const contactedCount = leads.filter(l => l.status === 'CONTACTED').length;
      const hotCount = leads.filter(l => l.heatScore >= 70).length;
      document.getElementById('stat-leads-new').innerHTML =
        '<span class="w-2 h-2 rounded-full bg-blue-400"></span> Novych: ' + newCount;
      document.getElementById('stat-leads-contacted').innerHTML =
        '<span class="w-2 h-2 rounded-full bg-yellow-400"></span> Kontakt: ' + contactedCount;
      document.getElementById('stat-leads-hot').innerHTML =
        '<span class="w-2 h-2 rounded-full bg-red-400"></span> Hot: ' + hotCount;
    }
  } catch (e) {
    document.getElementById('stat-leads').textContent = '0';
  }

  // Load coder stats
  try {
    const res = await apiFetch('/api/coder?limit=1');
    if (res.success && res.data && res.data.length > 0) {
      const task = res.data[0];
      document.getElementById('stat-coder').textContent = task.status;
      document.getElementById('stat-coder-detail').textContent =
        task.prompt ? task.prompt.substring(0, 40) + '...' : 'Bez popisu';
    } else {
      document.getElementById('stat-coder').textContent = '0';
      document.getElementById('stat-coder-detail').textContent = 'Ziadne ulohy';
    }
  } catch (e) {
    document.getElementById('stat-coder').textContent = '--';
    document.getElementById('stat-coder-detail').textContent = 'Chyba nacitania';
  }

  // Load booking stats
  try {
    const res = await apiFetch('/api/booking/slots?days=7');
    if (res.success && res.data) {
      const slots = res.data;
      document.getElementById('stat-booking').textContent = slots.length;
      document.getElementById('stat-booking-detail').textContent =
        slots.length > 0 ? 'Dostupnych slotov' : 'Ziadne sloty';
    }
  } catch (e) {
    document.getElementById('stat-booking').textContent = '--';
    document.getElementById('stat-booking-detail').textContent = 'Chyba nacitania';
  }
});
</script>

<%- include('layouts/footer') %>
