{
  "name": "synapse-system",
  "version": "1.0.0",
  "description": "Synapse System — NestJS backend + Telegram Bot + Web Frontend",
  "main": "dist/main.js",
  "scripts": {
    "build": "prisma generate && nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "keywords": [],
  "author": "Janči",
  "license": "ISC",
  "packageManager": "pnpm@10.13.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "puppeteer",
      "@nestjs/core"
    ],
    "overrides": {
      "undici@7": ">=7.28.0",
      "multer@2": ">=2.2.0",
      "picomatch@4": ">=4.0.4",
      "fast-uri@3": ">=3.1.2"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@octokit/rest": "^22.0.1",
    "@prisma/client": "^6.19.3",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ejs": "^5.0.1",
    "googleapis": "^171.4.0",
    "grammy": "^1.44.0",
    "puppeteer": "^24.43.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "simple-git": "^3.36.0",
    "uuid": "^13.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^25.4.0",
    "@types/uuid": "^11.0.0",
    "eslint": "^10.6.0",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
