generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== LEADS ====================

model Lead {
  id              String     @id @default(uuid())
  authorName      String
  profileUrl      String?
  postUrl         String?
  messengerUrl    String?
  groupName       String?
  postSummary     String     @db.Text
  publicComment   String?    @db.Text
  privateMessage  String?    @db.Text
  source          String     @default("facebook")
  category        String?
  confidence      Float?

  // Research
  researchSummary   String?    @db.Text
  trustScore        Int?       @default(0)
  linkedinUrl       String?
  companyName       String?
  companyRegNumber  String?
  companyInfo       String?    @db.Text
  companyRevenue    String?
  companyFoundedYear Int?
  clientWebsite     String?
  socialProfiles    String?    @db.Text

  // Web analysis
  webAnalysis       String?    @db.Text
  priceEstimate     String?

  // Tracking
  heatScore         Int        @default(10)
  linkOpened        Boolean    @default(false)
  linkOpenedAt      DateTime?
  formStarted       Boolean    @default(false)
  formCompleted     Boolean    @default(false)
  previewGenerated  Boolean    @default(false)
  previewViews      Int        @default(0)
  previewTotalTime  Int        @default(0)
  lastPreviewViewAt DateTime?

  // AI Learning
  messageVariant    String?
  responseType      String?

  // Status
  status            LeadStatus @default(NEW)
  contactedAt       DateTime?
  reminderSentAt    DateTime?
  followUpSentAt    DateTime?
  isBlacklisted     Boolean    @default(false)

  emailMessageId  String?    @unique
  rawEmailSnippet String?    @db.Text
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  notes           Note[]
  activities      LeadActivity[]

  @@index([status])
  @@index([status, createdAt])
  @@index([createdAt])
}

model Note {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([leadId])
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  event     String
  metadata  String?  @db.Text
  createdAt DateTime @default(now())

  @@index([leadId])
}

model Blacklist {
  id        String   @id @default(uuid())
  name      String
  profileUrl String?
  reason    String?
  createdAt DateTime @default(now())
}

model MessagePerformance {
  id             String   @id @default(uuid())
  leadId         String
  variant        String
  messageType    String
  toneStyle      String?
  phraseUsed     String?  @db.Text
  linkType       String?
  resultAction   String?
  convertedToCall Boolean @default(false)
  convertedToSale Boolean @default(false)
  saleAmount      Float?
  createdAt      DateTime @default(now())
}

enum LeadStatus {
  NEW
  CONTACTED
  REPLIED
  QUALIFIED
  CONVERTED
  REJECTED
}

// ==================== BOOKING ====================

model Booking {
  id              String        @id @default(uuid())
  clientName      String
  clientEmail     String
  clientPhone     String?
  dateTime        DateTime
  meetLink        String?
  calendarEventId String?
  leadId          String?
  status          BookingStatus @default(PENDING)
  notes           String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([dateTime])
  @@index([status])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ==================== AI CODER ====================

model CoderTask {
  id             String     @id @default(uuid())
  source         String     @default("telegram")
  telegramChatId String?
  command        String     @default("code")
  prompt         String     @db.Text
  response       String?    @db.Text
  generatedFiles String?    @db.Text
  repoUrl        String?
  deployUrl      String?
  status         TaskStatus @default(PENDING)
  duration       Int?
  createdAt      DateTime   @default(now())
  completedAt    DateTime?

  @@index([status])
  @@index([createdAt])
}

enum TaskStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ==================== FIGMA PIPELINE ====================

model DesignTask {
  id             String           @id @default(uuid())
  figmaUrl       String
  figmaFileKey   String
  figmaNodeIds   String?
  fileName       String?
  submittedBy    String           @default("telegram")
  status         DesignTaskStatus @default(PENDING)
  generatedCode  String?          @db.Text
  outputPath     String?
  previewUrl     String?
  errorMessage   String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  processedAt    DateTime?

  @@index([status])
  @@index([createdAt])
}

enum DesignTaskStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ==================== WEB CLONER ====================

model CloneRequest {
  id             String      @id @default(uuid())
  sourceUrl      String
  clientName     String
  clientEmail    String
  businessName   String
  businessField  String
  businessInfo   String      @db.Text
  additionalInfo String?     @db.Text
  clientPhone    String?
  leadId         String?
  trackingRef    String?     @unique
  status         CloneStatus @default(PENDING)
  previewUrl     String?
  generatedHtml  String?     @db.Text
  screenshotPath String?
  errorMessage   String?     @db.Text
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  completedAt    DateTime?

  @@index([status])
  @@index([createdAt])
}

enum CloneStatus {
  PENDING
  SCRAPING
  GENERATING
  COMPLETED
  FAILED
}

// ==================== CONTENT STUDIO ====================

model BrandProfile {
  id                 String   @id @default(uuid())
  brandName          String
  industry           String?
  targetAudience     String?  @db.Text
  communicationStyle String?  @db.Text
  addressing         String   @default("tykanie")
  preferredPhrases   Json?
  forbiddenPhrases   Json?
  requiredCtas       Json?
  humorLevel         Int      @default(3)
  formalityLevel     Int      @default(3)
  energyLevel        Int      @default(3)
  trustRules         String?  @db.Text
  complianceNotes    String?  @db.Text
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model KnowledgeDoc {
  id        String   @id @default(uuid())
  title     String
  category  String?
  content   String   @db.Text
  tags      Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model ContentSession {
  id               String               @id @default(uuid())
  type             ContentSessionType
  title            String?
  status           ContentSessionStatus @default(PENDING)
  transcript       String?              @db.Text
  summary          String?              @db.Text
  extractedData    Json?
  durationSeconds  Int?
  audioStoragePath String?
  saveAudio        Boolean              @default(false)
  errorMessage     String?              @db.Text
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  ideas            ContentIdea[]

  @@index([status])
  @@index([createdAt])
}

model ContentIdea {
  id                  String            @id @default(uuid())
  sessionId           String?
  session             ContentSession?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  title               String
  description         String?           @db.Text
  keyMessage          String?           @db.Text
  suggestedGoal       String?
  suggestedPillarId   String?
  suggestedTemplateId String?
  sourceType          String            @default("text_note")
  status              ContentIdeaStatus @default(NEW)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  scripts             ReelScript[]

  @@index([status])
  @@index([createdAt])
}

model ScriptTemplate {
  id                 String   @id @default(uuid())
  name               String
  description        String?  @db.Text
  structure          Json
  recommendedGoal    String?
  recommendedLength  String?
  recommendedStyle   String?
  recommendedEmotion String?
  hookPattern        String?  @db.Text
  bodyPattern        String?  @db.Text
  ctaPattern         String?  @db.Text
  complianceRules    String?  @db.Text
  isSystemTemplate   Boolean  @default(false)
  isFavorite         Boolean  @default(false)
  isDefault          Boolean  @default(false)
  isArchived         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([isArchived])
}

model InspirationSource {
  id                String          @id @default(uuid())
  type              InspirationType
  title             String
  sourceUrl         String?
  storagePath       String?
  transcript        String?         @db.Text
  userNotes         String?         @db.Text
  extractedPatterns Json?
  status            String          @default("new")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([type])
}

model ContentPillar {
  id              String   @id @default(uuid())
  name            String
  description     String?  @db.Text
  priority        Int      @default(0)
  targetFrequency String?
  complianceNotes String?  @db.Text
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive])
}

model ContentPlan {
  id                String            @id @default(uuid())
  name              String
  startDate         DateTime
  endDate           DateTime
  postsPerWeek      Int               @default(3)
  goals             Json?
  status            ContentPlanStatus @default(DRAFT)
  generationContext Json?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  items             ContentPlanItem[]

  @@index([status])
}

model ContentPlanItem {
  id             String            @id @default(uuid())
  contentPlanId  String
  plan           ContentPlan       @relation(fields: [contentPlanId], references: [id], onDelete: Cascade)
  scheduledDate  DateTime
  workingTitle   String
  topic          String?
  pillarId       String?
  templateId     String?
  goal           String?
  targetAudience String?
  length         String?
  style          String?
  emotion        String?
  suggestedHook  String?           @db.Text
  cta            String?           @db.Text
  status         ContentItemStatus @default(IDEA)
  sortOrder      Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  scripts        ReelScript[]

  @@index([contentPlanId])
  @@index([status])
  @@index([scheduledDate])
}

model ReelScript {
  id                String           @id @default(uuid())
  contentPlanItemId String?
  planItem          ContentPlanItem? @relation(fields: [contentPlanItemId], references: [id], onDelete: SetNull)
  contentIdeaId     String?
  idea              ContentIdea?     @relation(fields: [contentIdeaId], references: [id], onDelete: SetNull)
  versionName       String           @default("A")
  strategy          Json?
  hook              String?          @db.Text
  setup             String?          @db.Text
  mainMessage       String?          @db.Text
  keyInsight        String?          @db.Text
  cta               String?          @db.Text
  spokenScript      String?          @db.Text
  productionPlan    Json?
  instagramAssets   Json?
  safety            Json?
  reviewerScores    Json?
  reviewerFeedback  Json?
  status            ReelScriptStatus @default(DRAFT)
  isSelected        Boolean          @default(false)
  approvedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([status])
  @@index([contentPlanItemId])
  @@index([contentIdeaId])
}

model StylePreference {
  id              String                @id @default(uuid())
  sourceScriptId  String?
  preferenceType  String
  preferenceValue String                @db.Text
  confidence      Float                 @default(0.5)
  status          StylePreferenceStatus @default(PROPOSED)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([status])
  @@index([preferenceType])
}

model ContentJob {
  id          String           @id @default(uuid())
  type        String
  payload     Json?
  status      ContentJobStatus @default(QUEUED)
  attempts    Int              @default(0)
  maxAttempts Int              @default(3)
  lastError   String?          @db.Text
  result      Json?
  scheduledAt DateTime         @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status, scheduledAt])
  @@index([type])
}

enum ContentSessionType {
  QUICK_VOICE_NOTE
  AI_INTERVIEW
  TEXT_NOTE
  AUDIO_UPLOAD
}

enum ContentSessionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ContentIdeaStatus {
  NEW
  APPROVED
  CONVERTED
  REJECTED
  ARCHIVED
}

enum InspirationType {
  INSTAGRAM_PROFILE
  INSTAGRAM_REEL
  SCREENSHOT
  VIDEO_UPLOAD
  TRANSCRIPT
  MANUAL_NOTE
}

enum ContentPlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ContentItemStatus {
  IDEA
  PLANNED
  SCRIPT_DRAFT
  WAITING_FOR_APPROVAL
  APPROVED
  REJECTED
  READY_FOR_VIDEO
  COMPLETED
  ARCHIVED
}

enum ReelScriptStatus {
  DRAFT
  GENERATED
  UNDER_REVIEW
  EDITED
  APPROVED
  REJECTED
  READY_FOR_VIDEO
  ARCHIVED
}

enum StylePreferenceStatus {
  PROPOSED
  ACTIVE
  DISABLED
}

enum ContentJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ==================== CONTENT INTELLIGENCE (spec §14) ====================

model ContentVideoAsset {
  id              String               @id @default(uuid())
  title           String
  sourceType      String               @default("upload")
  sourceUrl       String?
  storagePath     String
  thumbnailPath   String?
  mimeType        String
  fileSizeBytes   Int
  durationSeconds Float?
  width           Int?
  height          Int?
  status          VideoAnalysisStatus  @default(UPLOADED)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  analyses        ContentVideoAnalysis[]
  metrics         ContentVideoMetric[]

  @@index([status])
  @@index([createdAt])
}

model ContentVideoAnalysis {
  id                 String              @id @default(uuid())
  videoAssetId       String
  videoAsset         ContentVideoAsset   @relation(fields: [videoAssetId], references: [id], onDelete: Cascade)
  status             VideoAnalysisStatus @default(QUEUED)
  language           String?
  transcript         String?             @db.Text
  summary            Json?
  contentStructure   Json?
  creativeAnalysis   Json?
  reusableInsights   Json?
  aiScores           Json?
  performanceHypotheses Json?
  evidenceLevel      String?
  providerMetadata   Json?
  errorMessage       String?             @db.Text
  approvedAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  segments           ContentVideoSegment[]

  @@index([videoAssetId])
  @@index([status])
}

model ContentVideoSegment {
  id                 String               @id @default(uuid())
  analysisId         String
  analysis           ContentVideoAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  startMs            Int
  endMs              Int
  transcriptText     String?              @db.Text
  visualDescription  String?              @db.Text
  onScreenText       String?
  editingEvents      Json?
  delivery           Json?
  purpose            String?
  attentionMechanism String?
  confidence         Float?
  sortOrder          Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([analysisId, sortOrder])
}

model ContentVideoMetric {
  id                      String            @id @default(uuid())
  videoAssetId            String
  videoAsset              ContentVideoAsset @relation(fields: [videoAssetId], references: [id], onDelete: Cascade)
  publishedAt             DateTime?
  followerCountAtPublish  Int?
  views                   Int?
  reach                   Int?
  likes                   Int?
  comments                Int?
  shares                  Int?
  saves                   Int?
  averageWatchTimeSeconds Float?
  completionRate          Float?
  source                  String            @default("manual")
  recordedAt              DateTime          @default(now())
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  @@index([videoAssetId])
}

model ContentDnaProfile {
  id                 String            @id @default(uuid())
  version            Int               @default(1)
  status             String            @default("draft")
  evidenceVideoCount Int               @default(0)
  dna                Json?
  approvedAt         DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  rules              ContentDnaRule[]

  @@index([status])
}

model ContentDnaRule {
  id                  String            @id @default(uuid())
  contentDnaProfileId String
  profile             ContentDnaProfile @relation(fields: [contentDnaProfileId], references: [id], onDelete: Cascade)
  category            String
  rule                String            @db.Text
  evidence            Json?
  confidence          Float             @default(0.5)
  status              DnaRuleStatus     @default(PROPOSED)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([contentDnaProfileId])
  @@index([status])
}

enum VideoAnalysisStatus {
  UPLOADED
  QUEUED
  PREPROCESSING
  TRANSCRIBING
  ANALYZING_SCENES
  ANALYZING_CONTENT
  GENERATING_INSIGHTS
  READY_FOR_REVIEW
  APPROVED
  FAILED
  ARCHIVED
}

enum DnaRuleStatus {
  PROPOSED
  APPROVED
  REJECTED
  DEACTIVATED
}

// ==================== PEŤOVÉ STUDIO (zjednodušený voice → skripty flow) ====================
// Izolované od Content Studia — vlastné lean tabuľky, Content Studio sa ich nedotýka.

model PetoBrand {
  id                 String   @id @default(uuid())
  brandName          String
  industry           String?
  targetAudience     String?  @db.Text
  communicationStyle String?  @db.Text
  addressing         String   @default("tykanie")
  preferredPhrases   Json?
  forbiddenPhrases   Json?
  requiredCtas       Json?
  notes              String?  @db.Text
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model PetoTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  structure   String?  @db.Text
  hookPattern String?  @db.Text
  ctaPattern  String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
}

model PetoDoc {
  id         String   @id @default(uuid())
  title      String
  sourceType String
  content    String   @db.Text
  charCount  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model PetoScript {
  id               String   @id @default(uuid())
  batchId          String
  sourceTranscript String?  @db.Text
  topic            String?
  versionName      String   @default("A")
  hook             String?  @db.Text
  setup            String?  @db.Text
  mainMessage      String?  @db.Text
  keyInsight       String?  @db.Text
  cta              String?  @db.Text
  spokenScript     String?  @db.Text
  productionPlan   Json?
  instagramAssets  Json?
  safety           Json?
  createdAt        DateTime @default(now())

  @@index([batchId])
  @@index([createdAt])
}
